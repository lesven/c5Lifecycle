{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'new' ? 'Neuer Benutzer' : 'Benutzer bearbeiten' }} – C5 Evidence Tool{% endblock %}

{% block body %}
<main class="admin-main">
  <h1>{{ mode == 'new' ? 'Neuer Benutzer' : 'Benutzer bearbeiten' }}</h1>

  {% if errors is not empty %}
    <div class="flash flash-error">
      Bitte korrigieren Sie die markierten Felder.
    </div>
  {% endif %}

  <form method="post" class="admin-form">
    <div class="form-group {{ errors.email is defined ? 'has-error' }}">
      <label for="email">E-Mail-Adresse <span class="required">*</span></label>
      <input type="email" id="email" name="email"
             value="{{ form_data.email }}" required
             autocomplete="email" placeholder="name@unternehmen.de">
      {% if errors.email is defined %}
        <span class="field-error">{{ errors.email }}</span>
      {% endif %}
    </div>

    <div class="form-group {{ errors.display_name is defined ? 'has-error' }}">
      <label for="display_name">Anzeigename <span class="required">*</span></label>
      <input type="text" id="display_name" name="display_name"
             value="{{ form_data.display_name }}" required
             placeholder="Max Mustermann">
      {% if errors.display_name is defined %}
        <span class="field-error">{{ errors.display_name }}</span>
      {% endif %}
    </div>

    <div class="form-group {{ errors.password is defined ? 'has-error' }}">
      <label for="password">
        Passwort {{ mode == 'new' ? '' : '(leer lassen für keine Änderung)' }}
        {% if mode == 'new' %}<span class="required">*</span>{% endif %}
      </label>
      <input type="password" id="password" name="password"
             {{ mode == 'new' ? 'required' }}
             autocomplete="new-password"
             minlength="8"
             placeholder="Mindestens 8 Zeichen">
      {% if errors.password is defined %}
        <span class="field-error">{{ errors.password }}</span>
      {% endif %}
    </div>

    <div class="form-group {{ errors.role is defined ? 'has-error' }}">
      <label for="role">Rolle <span class="required">*</span></label>
      <select id="role" name="role" required>
        <option value="ROLE_USER" {{ form_data.role == 'ROLE_USER' ? 'selected' }}>Benutzer</option>
        <option value="ROLE_ADMIN" {{ form_data.role == 'ROLE_ADMIN' ? 'selected' }}>Administrator</option>
      </select>
      {% if errors.role is defined %}
        <span class="field-error">{{ errors.role }}</span>
      {% endif %}
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">
        {{ mode == 'new' ? 'Benutzer anlegen' : 'Änderungen speichern' }}
      </button>
      <a href="{{ path('admin_users_index') }}" class="btn-secondary">Abbrechen</a>
    </div>
  </form>
</main>
{% endblock %}

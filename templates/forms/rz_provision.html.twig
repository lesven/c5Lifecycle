{% extends 'form_base.html.twig' %}

{% set form_title = 'Inbetriebnahme RZ-Asset' %}
{% set form_icon = '🖥' %}
{% set form_subtitle = 'C5 Evidence · RZ · Inbetriebnahme' %}
{% set track_class = 'track-a' %}
{% set track_label = 'Track A – RZ-Hardware' %}
{% set badge_class = 'badge-a' %}
{% set event_type = 'rz_provision' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Asset-Stammdaten</legend>
      {{ f.text_field('asset_id', 'Asset-ID / Inventarnummer', true, 'z. B. SRV-042') }}
      {{ f.dynamic_select('device_type', 'Gerätetyp', true, true) }}
      {{ f.dynamic_select('nutzungstyp', 'Nutzungstyp', true, false) }}
      {{ f.text_field('manufacturer', 'Hersteller', false) }}
      {{ f.text_field('model', 'Modell', false) }}
      {{ f.text_field('serial_number', 'Seriennummer', false) }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Standort &amp; Zuordnung</legend>
      <div id="location-loading" class="field-group location-loading-hint hidden">
        <span class="loading-text">Standort-Daten werden geladen …</span>
      </div>
      <div id="location-error" class="field-group location-error-hint hidden">
        <span class="error-text">⚠ Standort-Daten konnten nicht geladen werden (NetBox nicht erreichbar). Das Formular kann nicht eingereicht werden.</span>
      </div>
      {{ f.named_select('region', 'Region', true) }}
      {{ f.named_select('site_group', 'Standortgruppe', true, '– Bitte zuerst Region wählen –') }}
      {{ f.named_select('site', 'Standort', true, '– Bitte zuerst Standortgruppe wählen –') }}
      {{ f.date_field('commission_date', 'Datum Inbetriebnahme', true) }}
      {{ f.contact_select('asset_owner', 'Asset Owner (Name/Rolle)', true) }}
      {{ f.text_field('service', 'Zugehöriger Service/Plattform', false) }}
      {{ f.select_field('criticality', 'Kritikalität', ['hoch', 'mittel', 'niedrig'], true) }}
      {{ f.text_field('change_ref', 'Change-/Ticket-Referenz', true) }}
      {{ f.tenant_select() }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Betriebsbereitschaft</legend>
      {{ f.checkbox_field('monitoring_active', 'Monitoring aktiv', true) }}
      {{ f.checkbox_field('patch_process', 'Patch/Firmware-Prozess definiert', true) }}
      {{ f.checkbox_field('access_controlled', 'Zugriff nur über berechtigte Admin-Gruppen', true) }}
    </fieldset>
{% endblock %}

{% extends 'form_base.html.twig' %}

{% set form_title = 'Verpflichtung Admin-User' %}
{% set form_icon = '📝' %}
{% set form_subtitle = 'C5 Evidence · ADM · Verpflichtung' %}
{% set track_class = 'track-b' %}
{% set track_label = 'Track B – Admin-Endgeräte' %}
{% set badge_class = 'badge-b' %}
{% set event_type = 'admin_user_commitment' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Admin-User &amp; Asset</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.text_field('admin_user', 'Admin-User (Name + Mail/ID)', true) }}
      {{ f.date_field('commitment_date', 'Datum', true) }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Verpflichtungen</legend>
      {{ f.checkbox_field('admin_tasks_only', 'Nur Admin-Tätigkeiten', true) }}
      {{ f.checkbox_field('no_mail_office', 'Kein Mail/Office/Surfing', true) }}
      {{ f.checkbox_field('no_credential_sharing', 'Keine Weitergabe von Credentials', true) }}
      {{ f.checkbox_field('report_loss', 'Verlust sofort melden', true) }}
      {{ f.checkbox_field('return_on_change', 'Rückgabe bei Rollenwechsel/Austritt', true) }}
    </fieldset>
{% endblock %}

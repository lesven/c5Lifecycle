{% extends 'form_base.html.twig' %}

{% set form_title = 'Rückgabe Admin-Endgerät' %}
{% set form_icon = '📦' %}
{% set form_subtitle = 'C5 Evidence · ADM · Rückgabe' %}
{% set track_class = 'track-b' %}
{% set track_label = 'Track B – Admin-Endgeräte' %}
{% set badge_class = 'badge-b' %}
{% set event_type = 'admin_return' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Rückgabedaten</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.text_field('admin_user', 'Admin-User (Name/ID)', true) }}
      {{ f.date_field('return_date', 'Rückgabedatum', true) }}
      {{ f.select_field('return_reason', 'Rückgabegrund', ['Rollenwechsel', 'Austritt', 'Ersatz'], true) }}
      {{ f.select_field('condition', 'Zustand', ['OK', 'Defekt'], true) }}
      {{ f.select_field('accessories_complete', 'Zubehör vollständig', ['Ja', 'Nein'], true) }}
    </fieldset>
{% endblock %}

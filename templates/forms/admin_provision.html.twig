{% extends 'form_base.html.twig' %}

{% set form_title = 'Inbetriebnahme Admin-Endgerät' %}
{% set form_icon = '💻' %}
{% set form_subtitle = 'C5 Evidence · ADM · Inbetriebnahme' %}
{% set track_class = 'track-b' %}
{% set track_label = 'Track B – Admin-Endgeräte' %}
{% set badge_class = 'badge-b' %}
{% set event_type = 'admin_provision' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Gerätedaten</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.dynamic_select('device_type', 'Gerätetyp', true, true) }}
      {{ f.text_field('manufacturer', 'Hersteller', false) }}
      {{ f.text_field('model', 'Modell', false) }}
      {{ f.text_field('serial_number', 'Seriennummer', false) }}
      {{ f.date_field('commission_date', 'Datum Inbetriebnahme', true) }}
      {{ f.text_field('admin_user', 'Zugewiesener Admin-User (Name + Mail/ID)', true) }}
      {{ f.text_field('security_owner', 'Security Owner (Name/Rolle)', true) }}
      {{ f.text_field('purpose', 'Zweck / Privileged Role', true, 'z. B. Firewall Admin') }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Baseline Hardening</legend>
      {{ f.checkbox_field('disk_encryption', 'Disk Encryption aktiv', true) }}
      {{ f.checkbox_field('mfa_active', 'MFA aktiv', true) }}
      {{ f.checkbox_field('edr_active', 'EDR/AV aktiv', true) }}
      {{ f.checkbox_field('patch_process', 'Patch-Prozess aktiv', true) }}
      {{ f.checkbox_field('no_private_use', 'Keine private Nutzung', true) }}
    </fieldset>
{% endblock %}

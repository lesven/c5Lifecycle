{% extends 'form_base.html.twig' %}

{% set form_title = 'Owner-Betriebsbestätigung' %}
{% set form_icon = '✅' %}
{% set form_subtitle = 'C5 Evidence · RZ · Betriebsbestätigung' %}
{% set track_class = 'track-a' %}
{% set track_label = 'Track A – RZ-Hardware' %}
{% set badge_class = 'badge-a' %}
{% set event_type = 'rz_owner_confirm' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Asset &amp; Owner</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.contact_select('owner', 'Owner (Name/Rolle)', true) }}
      {{ f.date_field('confirm_date', 'Datum', true) }}
      {{ f.tenant_select() }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Bestätigungen</legend>
      {{ f.checkbox_field('purpose_bound', 'Zweckgebundener Betrieb', true) }}
      {{ f.checkbox_field('admin_access_controlled', 'Admin-Zugriffe kontrolliert', true) }}
      {{ f.checkbox_field('maintenance_window_ok', 'Wartungsfenster abgestimmt', true) }}
    </fieldset>
{% endblock %}

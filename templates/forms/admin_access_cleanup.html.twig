{% extends 'form_base.html.twig' %}

{% set form_title = 'Privileged Access Cleanup (IAM)' %}
{% set form_icon = '🔒' %}
{% set form_subtitle = 'C5 Evidence · ADM · Access Cleanup' %}
{% set track_class = 'track-b' %}
{% set track_label = 'Track B – Admin-Endgeräte' %}
{% set badge_class = 'badge-b' %}
{% set event_type = 'admin_access_cleanup' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Zuordnung</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.text_field('admin_user', 'Admin-User (Name/ID)', true) }}
      {{ f.date_field('cleanup_date', 'Datum', true) }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Durchgeführte Maßnahmen</legend>
      {{ f.checkbox_field('account_removed', 'Admin-Account entfernt/angepasst', true) }}
      {{ f.checkbox_field('keys_revoked', 'Keys/Zertifikate revoked', true) }}
      {{ f.checkbox_field('device_wiped', 'Gerät wiped oder reprovisioniert', false) }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Nachverfolgung</legend>
      {{ f.conditional_text_field('ticket_ref', 'Ticket-Referenz', 'device_wiped:unchecked', 'Pflicht wenn Wipe nicht abgeschlossen') }}
    </fieldset>
{% endblock %}

{% extends 'form_base.html.twig' %}

{% set form_title = 'Außerbetriebnahme RZ-Asset' %}
{% set form_icon = '⛔' %}
{% set form_subtitle = 'C5 Evidence · RZ · Außerbetriebnahme' %}
{% set track_class = 'track-a' %}
{% set track_label = 'Track A – RZ-Hardware' %}
{% set badge_class = 'badge-a' %}
{% set event_type = 'rz_retire' %}

{% import 'macros/form_fields.html.twig' as f %}

{% block form_fields %}
    <fieldset class="form-section">
      <legend>Asset-Daten</legend>
      {{ f.text_field('asset_id', 'Asset-ID', true) }}
      {{ f.date_field('retire_date', 'Datum Stilllegung', true) }}
      {{ f.select_field('reason', 'Grund', ['EOL', 'Defekt', 'Migration', 'Sonstiges'], true) }}
      {{ f.contact_select('owner_approval', 'Freigabe durch Owner', true) }}
      {{ f.select_field('followup', 'Folgeweg', ['Entsorgung', 'Leasing-Rückgabe', 'Ersatzteilspender'], true) }}
      {{ f.tenant_select() }}
    </fieldset>

    <fieldset class="form-section">
      <legend>Data Handling</legend>
      {{ f.radio_group('data_handling', ['Secure Wipe', 'Physische Zerstörung', 'Löschzertifikat Dienstleister', 'Nicht relevant'], true) }}
      {{ f.conditional_text_field('data_handling_ref', 'Nachweisreferenz', 'data_handling:!Nicht relevant', 'Pflicht wenn Data Handling ≠ Nicht relevant') }}
    </fieldset>
{% endblock %}

{
  "name": "c5-lifecycle-js-tests",
  "description": "Dev-only: Vitest JS-Tests für public/js/ (kein Browser-Build, kein Produktions-Toolchain)",
  "private": true,
  "type": "module",
  "scripts": {
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "test:js:coverage": "vitest run --coverage",
    "test:e2e": "testcafe chrome:headless tests/e2e --config-file .testcaferc.json",
    "test:e2e:headed": "testcafe chrome tests/e2e --config-file .testcaferc.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "testcafe": "^3.7.0",
    "vitest": "^2.1.0"
  }
}
